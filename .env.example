# Cookie persistence
COOKIE_FILE=sessions/linkedin_cookies.json

# User agent string (should match a real Chrome browser)
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Logging
RUST_LOG=info
LOG_DIR=./logs

# Automation
CSV_PATH=linkedin_profiles.csv
MIN_DELAY_MIN=10
MAX_DELAY_MIN=15

# Humanizer / anti-detection (per D5)
DAILY_WINDOW_START=09:00
DAILY_WINDOW_END=19:00
DAILY_SEND_CAP=18
DEGREE_RECHECK_DAYS=30
SKIP_SEND_PROBABILITY=0.07
BREAK_EVERY_MIN_SENDS=3
BREAK_EVERY_MAX_SENDS=7
BREAK_DURATION_MIN_SECS=1200
BREAK_DURATION_MAX_SECS=3600
DELAY_LOGNORMAL_MEDIAN_SECS=720
DELAY_LOGNORMAL_SIGMA=0.6
ME_PING_EVERY_N_SENDS=5
