# LinkedIn Credentials
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_password_here

# Browser Configuration
BROWSER_TYPE=chrome                    # chrome, firefox, edge
BROWSER_HEADLESS=false                 # true for headless mode
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1080
CHROMEDRIVER_PATH=/usr/local/bin/chromedriver
GECKODRIVER_PATH=/usr/local/bin/geckodriver

# WebDriver Configuration
WEBDRIVER_URL=http://localhost:4444    # Selenium Grid or local WebDriver

# Session Management
SESSION_DIR=./sessions                 # Directory for storing browser sessions
COOKIE_PERSISTENCE=true                # Save/restore cookies between runs

# Rate Limiting
MAX_PROFILE_VIEWS_PER_HOUR=50
MAX_CONNECTION_REQUESTS_PER_DAY=20
MAX_MESSAGES_PER_HOUR=10
ACTION_DELAY_MIN_MS=500                # Minimum delay between actions
ACTION_DELAY_MAX_MS=3000               # Maximum delay between actions

# Anti-Detection
RANDOMIZE_TIMING=true                  # Add random delays to mimic human behavior
SIMULATE_MOUSE_MOVEMENT=true
SIMULATE_SCROLLING=true
TYPING_DELAY_MIN_MS=50                 # Minimum delay between keystrokes
TYPING_DELAY_MAX_MS=150                # Maximum delay between keystrokes

# Proxy Configuration (optional)
USE_PROXY=false
PROXY_URL=http://proxy.example.com:8080
PROXY_USERNAME=
PROXY_PASSWORD=
ROTATE_PROXY=false                     # Rotate proxies for each session

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost/linkedin_automation
# DATABASE_URL=sqlite://data.db        # Alternative: SQLite

# Storage
DATA_EXPORT_DIR=./data
CACHE_TTL_HOURS=24                     # Cache TTL for profile data

# Logging
RUST_LOG=info                          # trace, debug, info, warn, error
LOG_DIR=./logs
LOG_TO_FILE=true
LOG_FORMAT=json                        # json or pretty

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_NOTIFICATIONS=false

# Scheduler (optional)
ENABLE_SCHEDULER=false
CRON_SCHEDULE=0 9 * * *                # Run daily at 9 AM

# LinkedIn API Keys (if using official API)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Feature Flags
ENABLE_NETWORK_ANALYSIS=true
ENABLE_PROFILE_SCORING=true
ENABLE_AUTO_CONNECT=false              # Automatically send connection requests
ENABLE_AUTO_MESSAGE=false              # Automatically send messages
ENABLE_AUTO_ENDORSE=false              # Automatically endorse skills

# Safety Limits
MAX_CONCURRENT_SESSIONS=3              # Maximum parallel browser sessions
FAIL_SAFE_MAX_ACTIONS_PER_DAY=100     # Absolute maximum actions per day

# Automation (Rust CLI)
CSV_PATH=linkedin_profiles.csv         # Path to profiles CSV
MIN_DELAY_MIN=10                       # Minimum delay after successful connection (minutes)
MAX_DELAY_MIN=15                       # Maximum delay after successful connection (minutes)
DEBUG_PORT=9222                        # Chrome DevTools Protocol debug port

# Development
DEV_MODE=false                         # Enable development features
MOCK_BROWSER=false                     # Use mock browser for testing
